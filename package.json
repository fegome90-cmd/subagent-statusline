{
	"name": "pi-subagent-statusline",
	"version": "0.1.0",
	"description": "Pi extension that monitors sub-agent status with semantic theming, flicker-free rendering, and progressive disclosure",
	"type": "module",
	"main": "extensions/index.ts",
	"keywords": [
		"pi-package"
	],
	"pi": {
		"extensions": [
			"./extensions/index.ts"
		]
	},
	"peerDependencies": {
