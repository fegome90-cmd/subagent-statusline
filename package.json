		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*",
		"typebox": "*"
	},
	"scripts": {
		"test": "node --import tsx --test extensions/test/*.ts"
	},
	"license": "MIT",
	"devDependencies": {
		"tsx": "^4.21.0"
	}
}
